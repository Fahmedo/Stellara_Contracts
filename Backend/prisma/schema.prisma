// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  reputationSignals    ReputationSignal[]
  endorsementsGiven    Endorsement[]        @relation("EndorsementsGiven")
  endorsementsReceived Endorsement[]        @relation("EndorsementsReceived")
  disputes             Dispute[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  esopGrants           EsopGrant[]
  capTableEntries      CapTableEntry[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model ReputationSignal {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  source      String   // e.g., "trading", "governance", "repayment"
  value       Float
  weight      Float    @default(1.0)
  timestamp   DateTime @default(now())
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("reputation_signals")
}

model Endorsement {
  id              String   @id @default(cuid())
  fromUserId      String   @map("from_user_id")
  toUserId        String   @map("to_user_id")
  fromUser        User     @relation("EndorsementsGiven", fields: [fromUserId], references: [id])
  toUser          User     @relation("EndorsementsReceived", fields: [toUserId], references: [id])
  weight          Float    @default(1.0)
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([fromUserId, toUserId])
  @@map("endorsements")
}

model Dispute {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  targetId        String   @map("target_id") // ID of the signal or endorsement being disputed
  reason          String
  status          String   @default("PENDING") // PENDING, RESOLVED, REJECTED
  resolution      String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("disputes")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model InsurancePolicy {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  poolId         String    @map("pool_id")
  riskType       RiskType  @map("risk_type")
  premium        Decimal   @map("premium")
  coverageAmount Decimal   @map("coverage_amount")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("claims")
}

model ReinsuranceContract {
  id             String   @id @default(cuid())
  poolId         String   @map("pool_id")
  coverageLimit  Decimal  @map("coverage_limit")
  premiumRate    Decimal  @map("premium_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reinsurance_contracts")
}

// ----------------------------------------------------------------------
// ESOP Management Module Models (Issue #538)
// ----------------------------------------------------------------------

model Organization {
  id              String   @id @default(cuid())
  name            String
  valuation409A   Decimal? @map("valuation_409a")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  grants          EsopGrant[]
  capTableEntries CapTableEntry[]
  valuations      ValuationHistory[]

  @@map("organizations")
}

model ValuationHistory {
  id            String       @id @default(cuid())
  orgId         String       @map("org_id")
  organization  Organization @relation(fields: [orgId], references: [id])
  valuation409A Decimal      @map("valuation_409a")
  effectiveDate DateTime     @map("effective_date")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("valuation_history")
}

enum EsopGrantType {
  ISO
  NSO
}

enum VestingFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum GrantStatus {
  ACTIVE
  CANCELLED
  FULLY_EXERCISED
}

enum ExerciseStatus {
  PENDING
  COMPLETED
  FAILED
}

model EsopGrant {
  id                  String          @id @default(cuid())
  orgId               String          @map("org_id")
  organization        Organization    @relation(fields: [orgId], references: [id])
  employeeId          String          @map("employee_id")
  employee            User            @relation(fields: [employeeId], references: [id])
  type                EsopGrantType
  totalShares         Int             @map("total_shares")
  strikePrice         Decimal         @map("strike_price")
  vestingPeriodMonths Int             @default(48) @map("vesting_period_months")
  cliffPeriodMonths   Int             @default(12) @map("cliff_period_months")
  vestingFrequency    VestingFrequency @default(MONTHLY) @map("vesting_frequency")
  startDate           DateTime        @map("start_date")
  exerciseWindowStart DateTime?       @map("exercise_window_start")
  exerciseWindowEnd   DateTime?       @map("exercise_window_end")
  status              GrantStatus     @default(ACTIVE)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  exercises           EsopExercise[]

  @@map("esop_grants")
}

model EsopExercise {
  id              String         @id @default(cuid())
  grantId         String         @map("grant_id")
  grant           EsopGrant      @relation(fields: [grantId], references: [id])
  shares          Int
  exercisePrice   Decimal        @map("exercise_price")
  taxWithheld     Decimal        @map("tax_withheld")
  status          ExerciseStatus @default(PENDING)
  executedAt      DateTime?      @map("executed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("esop_exercises")
}

model CapTableEntry {
  id              String       @id @default(cuid())
  orgId           String       @map("org_id")
  organization    Organization @relation(fields: [orgId], references: [id])
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id])
  sharesOwned     Int          @map("shares_owned")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([orgId, userId])
  @@map("cap_table_entries")
}

// ----------------------------------------------------------------------
// Security / Flash Loan Detection Module Models (Issue #537)
// ----------------------------------------------------------------------

enum AttackType {
  ORACLE_MANIPULATION
  LIQUIDATION_CASCADE
  GOVERNANCE_ATTACK
  UNKNOWN
}

enum MitigationStatus {
  DETECTED
  PAUSED
  RESOLVED
}

model FlashLoanDetection {
  id              String           @id @default(cuid())
  transactionHash String           @unique @map("transaction_hash")
  network         String
  loanAmount      Decimal          @map("loan_amount")
  tokenAddress    String           @map("token_address")
  attackType      AttackType       @map("attack_type")
  status          MitigationStatus @default(DETECTED)
  evidence        Json?            // Forensics data / Forta payload
  detectedAt      DateTime         @default(now()) @map("detected_at")
  resolvedAt      DateTime?        @map("resolved_at")

  @@map("flash_loan_detections")
}

